# Copied to `.env` locally — never commit real secrets.
# Only EXPO_PUBLIC_* vars are inlined into the JS bundle (public).

# Base URL for auth and API modules using `lib/api/httpClient` (default demo: https://reqres.in/api)
EXPO_PUBLIC_API_URL=https://reqres.in/api

# Google Maps SDK for Android — used at native build time (expo-maps). Not bundled as EXPO_PUBLIC_*.
# https://docs.expo.dev/versions/latest/sdk/maps/
GOOGLE_MAPS_ANDROID_API_KEY=
